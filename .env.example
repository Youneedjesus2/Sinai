APP_ENV=
# Dev (SQLite):   DATABASE_URL=sqlite:///./sinai.db
# Prod (Supabase/Postgres):  DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@host:5432/dbname
OPENAI_API_KEY=
DEFAULT_AGENCY_ID=default

# RingCentral SMS
RINGCENTRAL_CLIENT_ID=
RINGCENTRAL_CLIENT_SECRET=
RINGCENTRAL_JWT_TOKEN=
RINGCENTRAL_FROM_NUMBER=+1XXXXXXXXXX
RINGCENTRAL_WEBHOOK_VERIFICATION_TOKEN=
RINGCENTRAL_WEBHOOK_URL=
RINGCENTRAL_SUBSCRIPTION_ID=

# SendGrid Email
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Google Calendar
GOOGLE_CALENDAR_CREDENTIALS_JSON=
GOOGLE_CALENDAR_ID=

# Observability
LOG_LEVEL=INFO
PHOENIX_COLLECTOR_ENDPOINT=

# Supabase (production)
SUPABASE_URL=
SUPABASE_ANON_KEY=
